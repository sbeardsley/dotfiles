{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "black": "#1e1e2e",
    "blue": "#89b4fa",
    "green": "#a6e3a1",
    "orange": "#fab387",
    "red": "#f38ba8",
    "white": "#cdd6f4",
    "yellow": "#f9e2af"
  },
  "secondary_prompt": {
    "template": "<p:yellow,transparent>\ue0b6</><,p:yellow> > </><p:yellow,transparent>\ue0b0</> ",
    "foreground": "p:black",
    "background": "transparent"
  },
  "transient_prompt": {
    "template": "<p:yellow,transparent>\ue0b6</><,p:yellow> {{ .Folder }} </><p:yellow,transparent>\ue0b0</> ",
    "foreground": "p:black",
    "background": "transparent"
  },
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}}\ue0b1",
          "foreground": "p:black",
          "background": "p:yellow",
          "type": "os"
        },
        {
          "properties": {
            "style": "folder"
          },
          "style": "powerline",
          "template": " \uea83 {{ path .Path .Location }} ",
          "foreground": "p:black",
          "powerline_symbol": "\ue0b0",
          "background": "p:orange",
          "type": "path"
        },
        {
          "properties": {
            "branch_max_length": 25,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " {{ if .UpstreamURL }}{{ url .UpstreamIcon .UpstreamURL }} {{ end }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }} ",
          "foreground": "p:black",
          "powerline_symbol": "\ue0b0",
          "background": "p:green",
          "type": "git",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:black{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:white{{ end }}",
            "{{ if gt .Ahead 0 }}p:white{{ end }}"
          ],
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:red{{ end }}",
            "{{ if gt .Ahead 0 }}#49416D{{ end }}",
            "{{ if gt .Behind 0 }}#7A306C{{ end }}"
          ]
        },
        {
          "style": "powerline",
          "template": " \uf0e7 ",
          "foreground": "p:black",
          "powerline_symbol": "\ue0b0",
          "background": "p:yellow",
          "type": "root"
        },
        {
          "properties": {
            "always_enabled": true
          },
          "style": "diamond",
          "leading_diamond": "<transparent,background>\ue0b0</>",
          "trailing_diamond": "\ue0b4",
          "template": " {{ if gt .Code 0 }}\uf00d{{ else }}\uf00c{{ end }} ",
          "foreground": "p:black",
          "background": "p:blue",
          "type": "status",
          "background_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ]
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "properties": {
            "context_aliases": {
              "arn:aws:eks:eu-west-1:1234567890:cluster/posh": "posh",
              "docker-desktop": ""
            },
            "parse_kubeconfig": true
          },
          "style": "plain",
          "template": " \udb84\udcfe {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}} ",
          "foreground": "p:blue",
          "background": "transparent",
          "type": "kubectl"
        },
        {
          "properties": {
            "display_mode": "files",
            "fetch_package_manager": false,
            "home_enabled": false
          },
          "style": "plain",
          "template": " dotnet ",
          "foreground": "p:orange",
          "background": "transparent",
          "type": "dotnet"
        },
        {
          "properties": {
            "display_mode": "files",
            "fetch_package_manager": false,
            "home_enabled": false
          },
          "style": "plain",
          "template": "\ue718 ",
          "foreground": "p:green",
          "background": "transparent",
          "type": "node"
        },
        {
          "properties": {
            "fetch_version": false
          },
          "style": "plain",
          "template": "\ue626 ",
          "foreground": "p:blue",
          "background": "transparent",
          "type": "go"
        },
        {
          "properties": {
            "display_mode": "files",
            "fetch_version": false,
            "fetch_virtual_env": false
          },
          "style": "plain",
          "template": "\ue235 ",
          "foreground": "p:yellow",
          "background": "transparent",
          "type": "python"
        },
        {
          "style": "plain",
          "template": " \ue7a8 {{ .Full }} ",
          "foreground": "#193549",
          "background": "#99908a",
          "type": "rust"
        },
        {
          "style": "plain",
          "foreground": "#111111",
          "background": "#FFD664",
          "type": "upgrade"
        }
      ]
    }
  ],
  "tooltips": [
    {
      "properties": {
        "display_default": true
      },
      "style": "diamond",
      "leading_diamond": "\ue0b0",
      "trailing_diamond": "\ue0b4",
      "template": " \ue7ad {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} ",
      "foreground": "p:white",
      "background": "p:orange",
      "type": "aws",
      "tips": [
        "aws"
      ]
    },
    {
      "properties": {
        "display_default": true
      },
      "style": "diamond",
      "leading_diamond": "\ue0b0",
      "trailing_diamond": "\ue0b4",
      "template": " \uebd8 {{ .Name }} ",
      "foreground": "p:white",
      "background": "p:blue",
      "type": "az",
      "tips": [
        "az"
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
